# Copy this file to local.properties and fill in your SDK path.
# local.properties is gitignored — never commit it.

# Path to your Android SDK installation
# macOS example:
sdk.dir=/Users/YOUR_NAME/Library/Android/sdk

# Linux example:
# sdk.dir=/home/YOUR_NAME/Android/Sdk

# Windows example:
# sdk.dir=C\:\\Users\\YOUR_NAME\\AppData\\Local\\Android\\Sdk

# Optional: explicit NDK path (if not using the SDK-bundled NDK)
# ndk.dir=/path/to/ndk/27.x.x
